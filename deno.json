{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read main.ts",
    "lock": "deno cache --lock=deno.lock --lock-write main.ts",
    "check": "deno fmt --check && deno lint",
    "bundle": "deno bundle src/client/app.ts --outdir=public"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1.0.23",
    "geolib": "npm:geolib@3.3.4"
  }
}
